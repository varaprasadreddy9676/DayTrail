{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DayTrail",
  "version": "0.1.0",
  "identifier": "ai.daytrail.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DayTrail",
        "width": 1440,
        "height": 900,
        "minWidth": 1040,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["app", "dmg", "msi", "nsis"],
    "category": "Productivity",
    "shortDescription": "DayTrail local workday capture shell",
    "longDescription": "DayTrail helps you retrace your workday from local app, browser, editor, terminal, and AI usage metadata."
  }
}
