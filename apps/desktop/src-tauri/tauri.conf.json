{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DayTrail",

  "version": "0.1.35",
  "identifier": "ai.daytrail.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DayTrail",
        "width": 1440,
        "height": 900,
        "minWidth": 1040,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2ODg1MEUzMjUyOTgxMTkKUldRWmdTa2w0MUNJVnF1ZStoM2VJaHI4UXJqR2dPeUNUeTk5Q2JrUVFZS3JRVlZ2WVVWTzB0RUMK",
      "endpoints": [
        "https://github.com/varaprasadreddy9676/DayTrail/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["app", "dmg", "msi", "nsis"],
    "category": "Productivity",
    "shortDescription": "DayTrail local-first work memory",
    "longDescription": "DayTrail helps you retrace your workday from local app, browser, editor, terminal, AI usage, timesheet, and optional Smart Break metadata."
  }
}
